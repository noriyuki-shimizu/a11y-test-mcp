{
  "name": "a11y-test-mcp",
  "version": "1.3.2",
  "main": "build/index.js",
  "scripts": {
    "postinstall": "npx -y playwright install",
    "build": "tsc && chmod 755 build/index.js",
    "build:tsgo": "tsgo && chmod 755 build/index.js",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run lint:e && pnpm run lint:d",
    "lint:e": "eslint .",
    "lint:d": "dprint check",
    "format": "dprint fmt",
    "release:check": "pnpm install --frozen-lockfile && pnpm run lint && pnpm run typecheck && pnpm run build && npm pack --dry-run && pnpm publish --dry-run --no-git-checks"
  },
  "bin": {
    "a11y-test-mcp": "build/index.js"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "mcp",
    "playwright",
    "axe-core"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/noriyuki-shimizu/a11y-test-mcp.git"
  },
  "author": "Noriyuki Shimizu",
  "license": "ISC",
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build"
  ],
  "description": "",
  "homepage": "https://github.com/noriyuki-shimizu/a11y-test-mcp/blob/main/README.md",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260314.1",
    "dprint": "^0.52.0",
    "eslint": "^10.0.3",
    "eslint-config-flat-gitignore": "^2.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axe-core": "^4.11.4",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint"
    ]
  }
}
